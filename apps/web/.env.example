# Wanderverse web (Next.js) — copy to .env.local for local dev.

# Where the NestJS API lives (no trailing slash). Local dev default:
NEXT_PUBLIC_API_URL=http://localhost:3001

# Clerk authentication. The app boots WITHOUT these (public pages only,
# auth disabled — see middleware.ts / ADR-017), but sign-in needs both.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
